local Settings = {
    Enabled = true,
    ShowName = true,
    ShowDistance = true,
    MaxDistance = 450,
    TextColor = Color3.fromRGB(0, 255, 120),
    TextSize = 14,
    Outline = true,
}

local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

local Drawings = {}

local function IsItem(obj)
    if not obj or not obj.Parent then return false end
    if obj:IsA("Tool") then return true end
    
    local n = obj.Name:lower()
    return n:find("tool") or n:find("gun") or n:find("weapon") or n:find("loot") 
        or n:find("chest") or n:find("crate") or n:find("pickup") or n:find("coin")
end

local function CreateESP(item)
    if Drawings[item] then return end
    
    local text = Drawing.new("Text")
    text.Visible = false
    text.Color = Settings.TextColor
    text.Size = Settings.TextSize
    text.Outline = Settings.Outline
    text.Center = true
    text.Font = 2
    
    Drawings[item] = text
end

-- Main Loop - Using Heartbeat (more stable)
RunService.Heartbeat:Connect(function()
    if not Settings.Enabled then return end
    
    for item, draw in pairs(Drawings) do
        if not (item and item.Parent) then
            pcall(function() draw:Remove() end)
            Drawings[item] = nil
            continue
        end
        
        local root = item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart or item:FindFirstChild("Handle")
        if not root then
            draw.Visible = false
            continue
        end
        
        local distance = (Camera.CFrame.Position - root.Position).Magnitude
        if distance > Settings.MaxDistance then
            draw.Visible = false
            continue
        end
        
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
        
        if onScreen then
            local txt = Settings.ShowName and item.Name or ""
            if Settings.ShowDistance then
                txt = txt .. (txt ~= "" and " " or "") .. string.format("[%d]", math.floor(distance))
            end
            draw.Text = txt
            draw.Position = Vector2.new(pos.X, pos.Y)
            draw.Visible = true
        else
            draw.Visible = false
        end
    end
end)

-- Safe Scanning
spawn(function()
    while Settings.Enabled do
        for _, v in ipairs(workspace:GetDescendants()) do
            if IsItem(v) and not Drawings[v] then
                CreateESP(v)
            end
        end
        task.wait(4)
    end
end)

print("✅ [REX] Safe Item ESP Loaded (Heartbeat Version)")
print("Type Settings.Enabled = false to disable")
